@* src/Sfc.Web/Pages/Admin/Events/WeighIns.cshtml *@
@page "{eventId:guid}"
@using Sfc.Web.Services
@model Sfc.Web.Pages.Admin.Events.WeighInsModel
@{
    ViewData["Title"] = "Pesagem";
    var evt = Model.Event!;
    var fights = Model.Rows.GroupBy(r => new { r.FightId, r.FightOrder }).OrderBy(g => g.Key.FightOrder);
}
<div class="d-flex justify-content-between align-items-center mb-1">
    <h1 class="h3 mb-0">Pesagem</h1>
    <a asp-page="Edit" asp-route-id="@evt.Id" class="btn btn-link">Voltar ao evento</a>
</div>
<p class="text-muted mb-4">@evt.Name — @evt.Date.ToString("dd/MM/yyyy")</p>

@if (Model.Rows.Count == 0)
{
    <p class="text-muted">Sem combates no card — adicione combates ao evento primeiro.</p>
}

@foreach (var fight in fights)
{
    var any = fight.First();
    var weight = any.CatchweightKg is not null
        ? $"{any.CatchweightKg}kg (combinado)"
        : any.WeightClass ?? "—";
    <div class="card mb-3">
        <div class="card-header d-flex justify-content-between">
            <strong>Combate @any.FightOrder</strong>
            <span class="text-muted">@weight</span>
        </div>
        <div class="card-body p-2">
            @foreach (var row in fight.OrderBy(r => r.Corner))
            {
                <form method="post" asp-page-handler="Save" asp-route-fightId="@row.FightId"
                      asp-route-athleteId="@row.AthleteId"
                      class="row g-2 align-items-center border-bottom py-2 mx-0">
                    <div class="col-12 col-md-3">
                        <span class="badge @(row.Corner == Sfc.Domain.Events.Corner.Red ? "text-bg-danger" : "text-bg-primary")">@(row.Corner == Sfc.Domain.Events.Corner.Red ? "Vermelho" : "Azul")</span>
                        <strong>@row.AthleteName</strong>
                        @if (row.FightStatus == Sfc.Domain.Events.FightStatus.Cancelled)
                        {
                            <span class="badge text-bg-danger">Combate cancelado</span>
                        }
                        else if (row.FightStatus == Sfc.Domain.Events.FightStatus.NoContest)
                        {
                            <span class="badge text-bg-secondary">No contest</span>
                        }
                        @if (row.IsOverweight)
                        {
                            <span class="badge text-bg-danger">Não fez peso</span>
                        }
                        @if (row.IsApproved)
                        {
                            <span class="badge text-bg-success">Aprovado</span>
                        }
                    </div>
                    <div class="col-4 col-md-2">
                        <label class="form-label small mb-0">Esperado (kg)</label>
                        @* number inputs need an invariant "71.8" — pt-PT "71,8" is rejected *@
                        <input name="ExpectedWeightKg"
                               value="@((row.ExpectedWeightKg ?? row.WeightLimitKg)?.ToString(System.Globalization.CultureInfo.InvariantCulture))"
                               type="number" step="0.05" min="0" inputmode="decimal"
                               class="form-control form-control-sm" />
                    </div>
                    <div class="col-4 col-md-2">
                        <label class="form-label small mb-0">Oficial (kg)</label>
                        <input name="OfficialWeightKg"
                               value="@row.OfficialWeightKg?.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                               type="number" step="0.05" min="0" inputmode="decimal"
                               class="form-control form-control-sm @(row.IsOverweight ? "border-danger" : "")" />
                    </div>
                    <div class="col-4 col-md-2">
                        <div class="form-check mt-3">
                            <input name="IsApproved" value="true" type="checkbox"
                                   class="form-check-input" id="approve-@row.AthleteId"
                                   checked="@row.IsApproved" />
                            <label class="form-check-label" for="approve-@row.AthleteId">Aprovado</label>
                        </div>
                    </div>
                    <div class="col-8 col-md-2">
                        <label class="form-label small mb-0">Notas</label>
                        <input name="Notes" value="@row.Notes" class="form-control form-control-sm" maxlength="1000" />
                    </div>
                    <div class="col-4 col-md-1 text-end">
                        <button type="submit" class="btn btn-primary btn-sm mt-3">Gravar</button>
                    </div>
                    @if (row.WeighedAt is not null)
                    {
                        <div class="col-12 small text-muted">
                            Pesado às @PortugalTime.FromUtc(row.WeighedAt.Value).ToString("HH:mm dd/MM")
                        </div>
                    }
                </form>
            }
        </div>
    </div>
}

<script>
    // Double-submit guard: weak venue wi-fi invites double taps.
    document.querySelectorAll('main form').forEach(function (form) {
        form.addEventListener('submit', function () {
            setTimeout(function () {
                form.querySelectorAll('button[type="submit"]').forEach(function (b) { b.disabled = true; });
            }, 0);
        });
    });
</script>
